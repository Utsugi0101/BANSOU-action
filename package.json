{
  "name": "bansou-action",
  "version": "1.0.0",
  "description": "BANSOU PR gate action",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && ncc build dist/index.js -o dist-ncc && cp dist-ncc/index.js dist/index.js && rm -rf dist-ncc",
    "dev": "npm run build && node dist/index.js",
    "lint": "echo \"no lint configured\""
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "dotenv": "^16.4.5",
    "jose": "^5.6.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^5.4.5"
  }
}
